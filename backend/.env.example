# MediFind Backend — Environment Variables
# Copy to .env and fill in your values. Never commit .env.

# ── Neon PostgreSQL (free at https://neon.tech) ───────
# Format: postgresql://user:password@hostname/dbname?sslmode=require
NEON_DATABASE_URL=postgresql://medifind_owner:YOURPASSWORD@ep-YOURHOST.ap-south-1.aws.neon.tech/medifind?sslmode=require

# ── Groq API (free at https://console.groq.com) ───────
GROQ_API_KEY=gsk_REPLACE_WITH_YOUR_GROQ_KEY

# ── Embedding Model (runs locally, no API needed) ─────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ── App Settings ──────────────────────────────────────
CORS_ORIGINS=http://localhost:8080,http://localhost:5173,http://localhost:3000
MAX_RESULTS=20
DATA_DIR=./data/raw

# ── Groq Rate Limit ───────────────────────────────────
GROQ_REQUESTS_PER_MINUTE=28
