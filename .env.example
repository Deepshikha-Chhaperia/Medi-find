# MediFind example environment file
# Copy the relevant values into `.env` for local development and into Vercel project env vars for production.
# Never commit real secrets.

# Frontend
VITE_API_URL=http://localhost:8000
VITE_APP_NAME=MediFind
VITE_APP_VERSION=1.0.0

# Backend
# SQLite is used automatically (backend/db/medifind.db). No setup required.
# Backend-only Groq key. Do NOT prefix this with VITE_.
GROQ_API_KEY=

# Comma-separated allowed origins.
# Local example:
CORS_ORIGINS=

# Serverless-safe settings
DISABLE_LOCAL_MODELS=true

# Optional defaults for Admin -> Google Sheet ingestion
GOOGLE_SHEET_URL=
GOOGLE_SHEET_GID=


# Optional override. On Vercel the backend already runs sheet ingestion inline automatically.
# INGEST_INLINE=true
